---
import "../styles/article-list.css";

import { getCollection } from "astro:content";
import { openGraph } from "spectre:globals";
import Card from "../components/Card.astro";
import Icon from "../components/Icon.astro";
import PublicationTeaser from "../components/PublicationTeaser.astro";
import Layout from "../layouts/Layout.astro";

const publications = (await getCollection("publications")).sort(
	(a, b) =>
		b.data.year - a.data.year ||
		b.data.createdAt.getTime() - a.data.createdAt.getTime(),
);
---
<Layout
	title={openGraph.blog.title || "Full Publications"}
	description={openGraph.blog.description}
	pagefindIgnore
>
	<div class="layout-grid-left" slot="left">
		<Card class="flex-col-card">
			<h2 class="no-mt">Stats</h2>
			<div class="stats-div">
				<div class="stat">
					<h3 class="text-glow">{publications.length}</h3>
					<span>Publication{publications.length === 1 ? "" : "s"}</span>
				</div>
			</div>
		</Card>
	</div>
	<div class="layout-grid-right" slot="right">
		<Card>
			<div class="header-container">
				<Icon type="lucide" name="book-open" width={24} height={24} class="glow-icon" />
				<h2>Full Publications</h2>
			</div>
			<div class="content-container">
				{
					publications.map((publication) => (
						<PublicationTeaser
							publication={publication}
							href={`/publications/${publication.id}`}
							variant="full"
						/>
					))
				}
			</div>
		</Card>
	</div>
</Layout>
<style>
	.stats-div {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.stat {
		display: flex;
		flex-direction: column;
	}

	.stat h3 {
		font-size: 2em;
		margin: 0;
		margin-bottom: 0.5rem;
	}
</style>
