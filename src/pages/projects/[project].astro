---
import "../../styles/article.css";

import type { CollectionEntry } from "astro:content";
import { getCollection, render } from "astro:content";
import type { GetStaticPaths } from "astro";
import Card from "../../components/Card.astro";
import Icon from "../../components/Icon.astro";
import ImageGlow from "../../components/ImageGlow.astro";
import Layout from "../../layouts/Layout.astro";

interface Props {
	project: CollectionEntry<"projects">;
}

const { project } = Astro.props;

export const getStaticPaths = (async () => {
	const projects = await getCollection("projects");

	return projects.map((project) => ({
		params: { project: project.id },
		props: { project },
	}));
}) satisfies GetStaticPaths;

const { Content } = await render(project);
---

<Layout
	title={project.data.title}
	description={project.data.description}
	image={project.data.image}
	article={{
		createdAt: project.data.date,
	}}
>
	<div class="left" slot="left">
		<Card class="toc-card">
			<h2 class="no-mt">Info</h2>
			<ul class="overview-list">
				{
					project.data.info.map((info) => {
						const Tag = info.link ? "a" : "div";
						return (
							<li>
								<Tag href={info.link} class="project-info-item">
									<Icon
										type={info.icon.type}
										name={info.icon.name as any}
										width={24}
										height={24}
										class="glow-icon"
									/>
									<span>{info.text}</span>
								</Tag>
							</li>
						);
					})
				}
			</ul>
		</Card>
	</div>
	<article slot="right" data-pagefind-body>
		<Card>
			<div class="article-header" id="_top" data-pagefind-ignore>
				{
					project.data.image && (
						<ImageGlow
							quality={100}
							class="article-image"
							src={project.data.image}
							alt={project.data.title}
						/>
					)
				}
				<div class="header">
					<div>
						<h1 class="no-mt article-h1">{project.data.title}</h1>
					</div>
					<div class="article-info">
						<span>{project.data.date.toLocaleDateString()}</span>
					</div>
				</div>
			</div>
			<Content />
			<hr class="end-of-article" />
			<a href="/projects" class="block-link" data-pagefind-ignore
				>← Back to projects</a
			>
		</Card>
	</article>
</Layout>
<style>
	.project-info-item {
		display: flex;
		align-items: center;
		gap: 1rem;
	}

	.header {
		position: relative;
		bottom: auto;
		left: auto;
		max-width: none;
		margin-top: 1rem;
	}

	.article-h1 {
		display: inline;
		background: transparent;
		padding: 0;
		color: var(--text-primary);
	}

	.article-info {
		background: transparent;
		padding: 0;
		color: var(--text-secondary);
	}

	:global(.project-result-grid) {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		margin-top: 1rem;
	}

	:global(.project-result-card) {
		margin: 0;
		padding: 1rem;
		border: 1px solid var(--border-color);
		background: var(--surface-bg);
	}

	:global(.project-result-pair) {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
	}

	:global(.project-result-panel) {
		display: flex;
		flex-direction: column;
		gap: 0.65rem;
		padding: 0.9rem;
		border: 1px solid var(--border-color);
		background: rgba(255, 255, 255, 0.92);
	}

	:global(.project-result-label) {
		font-family: "Geist Mono", "Courier New", Courier, monospace;
		font-size: 0.78rem;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: #5f6472;
	}

	:global(.project-result-image) {
		display: block;
		width: 100%;
		height: auto;
		object-fit: contain;
	}

	:global(.project-result-caption) {
		margin-top: 0.85rem;
		line-height: 1.6;
		color: var(--text-secondary);
	}

	:global(.project-result-caption strong) {
		color: var(--text-primary);
	}

	@media screen and (max-width: 720px) {
		:global(.project-result-pair) {
			grid-template-columns: minmax(0, 1fr);
		}
	}
</style>
